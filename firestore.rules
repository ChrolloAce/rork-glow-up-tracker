rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Community posts (wins)
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.authorID == request.auth.uid;
      // Author can edit/delete their own post; anyone signed in may toggle likes.
      allow update: if request.auth != null && (
                      resource.data.authorID == request.auth.uid ||
                      request.resource.data.diff(resource.data)
                        .affectedKeys().hasOnly(['likedBy', 'likeCount', 'commentCount'])
                    );
      allow delete: if request.auth != null
                    && resource.data.authorID == request.auth.uid;

      // Comments on a post
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.resource.data.authorID == request.auth.uid;
        allow delete: if request.auth != null
                      && resource.data.authorID == request.auth.uid;
      }
    }

    // Leaderboard / user profiles
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Moderation reports — users can file, only admins (server) can read.
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }
  }
}
